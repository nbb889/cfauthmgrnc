{
    "name": "authmgr",
    "main": "src/app.js",
    "compatibility_date": "2026-06-02",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
        "directory": "./web/dist/",
        "binding": "assets"
    },
    "build": {
        "command": "npm install && cd web && npm install && npm run build"
    },
    "kv_namespaces": [
        {
            "binding": "data",
            "id": "70924e0c4ef74e8d91fa4ae45c6f7be7"
        }
    ]
}
