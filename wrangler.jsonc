{
    "name": "authmgr",
    "main": "src/app.js",
    "compatibility_date": "2026-06-02",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
        "directory": "./web/dist/",
        "binding": "assets"
    },
    "build": {
        "command": "npm install && cd web && npm install && npm run build"
    },
    "kv_namespaces": [
        {
            "binding": "data",
            "id": "a901905606354864ae747308e8898e26"
        }
    ]
}
